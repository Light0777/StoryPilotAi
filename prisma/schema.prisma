generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  characters   Character[]
}

model Character {
  id              String        @id @default(cuid())
  userId          String
  name            String
  personality     String
  missionPrompt   String
  storiesPerDay   Int           @default(2)
  faceReferenceUrl String?
  autoPublish     Boolean       @default(false)
  publishTime     String?
  status          String        @default("active")
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyPlans      StoryPlan[]
  generatedStories GeneratedStory[]
  memories        Memory[]

  @@index([userId])
}

model StoryPlan {
  id              String           @id @default(cuid())
  characterId     String
  date            DateTime
  location        String
  theme           String
  caption         String
  status          String           @default("planned")
  createdAt       DateTime         @default(now())
  character       Character        @relation(fields: [characterId], references: [id], onDelete: Cascade)
  generatedStories GeneratedStory[]

  @@index([characterId])
  @@index([date])
  @@index([characterId, date])
}

model GeneratedStory {
  id              String     @id @default(cuid())
  characterId     String
  storyPlanId     String?
  imageUrl        String
  caption         String
  published       Boolean    @default(false)
  publishedAt     DateTime?
  bufferPostId    String?
  status          String     @default("generated")
  createdAt       DateTime   @default(now())
  character       Character  @relation(fields: [characterId], references: [id], onDelete: Cascade)
  storyPlan       StoryPlan? @relation(fields: [storyPlanId], references: [id], onDelete: SetNull)

  @@index([characterId])
  @@index([status])
}

model Memory {
  id          String   @id @default(cuid())
  characterId String
  key         String
  value       String
  createdAt   DateTime @default(now())
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, key])
  @@index([characterId])
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
